# Postgres DB
DB_NAME=GoAdventureDB # Name of the Database (Can be left default)
DB_USER=postgres # DB User (Can be left default for development) (Do NOT leave default for production)
DB_PASSWORD=postgres # DB Password (Can be left default for development) (Do NOT leave default for production)
DB_ADDR=localhost # IP address of DB (If using only DB in container, can be left as 'localhost'). (If both DB and App are in containers, change to Container Service Name (i.e. postgres))
DB_PORT=5432 # Port for DB (Can be left default) (Change if default port already in use)

# Go Server
FILEPATH_ROOT=./public # Where files will be served from. (Can be left default)
PORT=8080 # Port that server will listen on (Can be left default) (Change to 443 for HTTPS)
ENV=development # Environment of Server. (i.e. 'development' or 'production') (This will be used in logs)
LOG_FILE=GoAdventure.access.log # Name of log file. (Logs will be saved in /logs)

# Secret
JWT_SECRET=1234567890abc # Secret Key for hashing. (Do NOT leave default)